{
  "cleanUrls": true,

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],

  "crons": [
    {
      "path": "/api/process-market-data",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/save-market-snapshot",
      "schedule": "0 */12 * * *"
    }
  ]
}
